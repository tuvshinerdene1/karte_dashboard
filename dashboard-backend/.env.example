PORT=8080
NODE_ENV=development

DB_HOST=localhost
DB_PORT=5432
DB_NAME=karte_dashboard
DB_USER=postgres
DB_PASSWORD=postgres

JWT_SECRET=change-me-in-production

# Set to true to bypass JWT for all API routes (local dev only)
DISABLE_AUTH=false

# Shared key used by the Python simulator (must match simulator SIMULATOR_API_KEY)
SIMULATOR_API_KEY=simulator-dev-key
